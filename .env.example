# === Auth ===
WINDY_PRO_JWKS_URL=https://windypro.thewindstorm.uk/.well-known/jwks.json
ETERNITAS_JWKS_URL=https://eternitas.thewindstorm.uk/.well-known/eternitas-keys

# === R2 Storage (optional — falls back to local disk) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=windy-cloud-storage
# R2_ENDPOINT=  # Auto-built from account ID if not set

# === Database ===
# SQLite for dev (default), PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///data/windy_cloud.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/windy_cloud

# === Compute - RunPod (optional) ===
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=
# STT_MARKUP=3.0
# STT_FREE_MINUTES=10

# === AWS (optional — for VPS provisioning) ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# === Server ===
HOST=0.0.0.0
PORT=8200
LOG_LEVEL=info

# Dev mode adds localhost to CORS origins
DEV_MODE=false

# CORS origins (comma-separated, localhost auto-added in dev mode)
CORS_ORIGINS=https://windypro.thewindstorm.uk

# === Quotas ===
DEFAULT_STORAGE_QUOTA=524288000
MAX_UPLOAD_SIZE=1073741824
MAX_SERVERS_PER_USER=5

# === Mock providers (for testing/dev without real cloud credentials) ===
USE_MOCK_PROVIDERS=false
