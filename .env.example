# Windy Cloud — example environment. Copy to .env and fill in.
# Production values live in AWS Secrets Manager; see deploy/docs/env-vars.md.

# === Auth (JWKS) ===
WINDY_PRO_JWKS_URL=https://windyword.ai/.well-known/jwks.json
ETERNITAS_JWKS_URL=https://eternitas.ai/.well-known/eternitas-keys

# Optional audience / issuer enforcement (Wave 7 G7). Empty = off,
# matches pre-Wave-7 behaviour; set in prod once windy-pro + Eternitas
# agree on canonical aud / iss values.
WINDY_CLOUD_EXPECTED_AUDIENCE=
WINDY_PRO_EXPECTED_ISSUER=
ETERNITAS_EXPECTED_ISSUER=

# === Eternitas Trust API ===
# Production: https://eternitas.ai. Local dev: http://localhost:8500.
ETERNITAS_URL=http://localhost:8500
# Set to "true" to short-circuit the trust client (offline dev / CI).
ETERNITAS_USE_MOCK=false
# HMAC-SHA256 secret for verifying inbound passport.* + trust.changed
# webhooks. Must match the per-platform secret Eternitas returned at
# platform registration. MINT: `openssl rand -hex 32`.
ETERNITAS_WEBHOOK_SECRET=
TRUST_CACHE_TTL_SECONDS=300
TRUST_HTTP_TIMEOUT_SECONDS=3.0

# === Shared service-to-service secrets ===
# HMAC-SHA256 secret shared with windy-pro for /api/v1/webhooks/identity/created.
# MINT: `openssl rand -hex 32`.
IDENTITY_WEBHOOK_SECRET=
# Shared bearer for internal service-to-service calls (archive uploads,
# billing/allocate, identity bridge). Rolled across mail/chat/word/clone/
# agent + cloud together. MINT: `openssl rand -base64 48 | tr -d '='`.
SERVICE_TOKEN=

# === R2 storage (optional — falls back to local disk if unset) ===
# Set all four of R2_ACCOUNT_ID/R2_ACCESS_KEY_ID/R2_SECRET_ACCESS_KEY
# + R2_BUCKET together, or leave them all empty to use the local-disk
# provider (dev-only). Partial config is rejected at startup (GAP G4).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=windy-cloud-storage
# Auto-built from R2_ACCOUNT_ID if unset, as
# `https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com`. Only override to
# point at a non-Cloudflare S3-compatible endpoint. Leaving this empty
# requires R2_ACCOUNT_ID to be set.
R2_ENDPOINT=

# === Database ===
# SQLite for dev (default); PostgreSQL+asyncpg for prod.
DATABASE_URL=sqlite+aiosqlite:///data/windy_cloud.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/windy_cloud

# === Compute — RunPod (Phase 1, optional) ===
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
STT_MARKUP=3.0
STT_FREE_MINUTES=10

# === Compute — SageMaker (Phase 2, optional — fallback when RunPod is down) ===
SAGEMAKER_ENDPOINT_NAME=

# === AWS (for VPS provisioning, SageMaker, EC2) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# === Deployment ===
# EC2 public IP or domain for CI/CD SSH target.
DEPLOY_HOST=
# POSTGRES_PASSWORD=changeme  # Used by docker-compose PostgreSQL

# === Server ===
HOST=0.0.0.0
PORT=8200
LOG_LEVEL=info
# Dev mode: adds localhost to CORS origins + exposes /docs, /redoc, /openapi.json.
DEV_MODE=false
CORS_ORIGINS=https://windyword.ai,https://windycloud.com

# === Tier quotas (bytes) ===
# Base quotas before Eternitas tier_multiplier is applied.
TIER_QUOTA_FREE=5368709120
TIER_QUOTA_PRO=107374182400
TIER_QUOTA_ULTRA=1099511627776
TIER_QUOTA_MAX=5497558138880

# Legacy per-user fallback (used only when a user has no UserPlan row).
DEFAULT_STORAGE_QUOTA=524288000
# Hard ceiling on a single upload — keep well below Fargate task memory.
MAX_UPLOAD_SIZE=1073741824
MAX_SERVERS_PER_USER=5

# === Observability ===
SENTRY_DSN=

# === Misc ===
PRICING_URL=https://windyword.ai/pricing
# Set true only for tests — swaps real storage/compute providers for mocks.
USE_MOCK_PROVIDERS=false
