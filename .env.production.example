# Windy Cloud — production environment template
#
# Copy to .env.production on the API host (or load from AWS Secrets
# Manager via deploy/scripts/fetch-secrets.sh). Every `CHANGEME` value
# MUST be replaced before `systemctl start windycloud`.
#
# Rotation cadence: HMAC secrets + JWT-signing keys every 90 days,
# R2 + AWS keys every 180 days, Stripe webhook secret on every
# compromise or quarterly. See DEPLOY.md §4.

# ===================================================================
# Identity / auth — inbound JWTs
# ===================================================================

# Windy Pro account-server JWKS (identity authority for humans).
# Wave 13 Phase 3: the canonical prod host. Phase 1 must be live before
# Cloud starts — otherwise every request 401s on JWT validation because
# the JWKS fetch times out. See docs/WAVE13_PHASE3_RUNBOOK.md.
WINDY_PRO_JWKS_URL=https://api.windyword.ai/.well-known/jwks.json

# Eternitas JWKS (identity authority for bots / agents — Phase 2).
ETERNITAS_JWKS_URL=https://api.eternitas.ai/.well-known/eternitas-keys

# REQUIRED in prod (Wave 7 G7) — rejects tokens minted for another
# Windy product even when signed by the same hub. Leave empty in dev.
WINDY_CLOUD_EXPECTED_AUDIENCE=windy-cloud
WINDY_PRO_EXPECTED_ISSUER=https://api.windyword.ai
ETERNITAS_EXPECTED_ISSUER=https://api.eternitas.ai

# ===================================================================
# Eternitas Trust API (Wave 3/4 — passport trust-tier lookups)
# ===================================================================

ETERNITAS_URL=https://api.eternitas.ai
ETERNITAS_USE_MOCK=false
# HMAC secret for the inbound trust.changed webhook. Share with
# Eternitas ops; rotate together.
ETERNITAS_WEBHOOK_SECRET=CHANGEME
TRUST_CACHE_TTL_SECONDS=300
TRUST_HTTP_TIMEOUT_SECONDS=3.0

# ===================================================================
# Webhook secrets (inbound + outbound HMAC)
# ===================================================================

# Windy Pro → Cloud: /webhooks/identity/created, /billing/sync, etc.
# MINT: `openssl rand -hex 32`. Roll in lockstep with Windy Pro.
IDENTITY_WEBHOOK_SECRET=CHANGEME

# Shared bearer for service-to-service calls across the ecosystem
# (archive uploads, billing/allocate, identity bridge). Rolled across
# mail/chat/word/clone/agent + cloud together.
# MINT: `openssl rand -base64 48 | tr -d '='`.
SERVICE_TOKEN=CHANGEME

# Outbound to users — signs the email-verification / export-ready
# links we send. Anyone with this secret can forge our outbound
# webhook signatures; keep in Secrets Manager.
OUTBOUND_WEBHOOK_HMAC_SECRET=CHANGEME

# Windy Chat push-gateway (Wave 8 — grandma-ribbon first-backup).
CHAT_PUSH_GATEWAY_URL=https://chat.windyfly.ai/api/v1/push
CHAT_PUSH_SERVICE_TOKEN=CHANGEME

# ===================================================================
# Cold storage — Cloudflare R2 (primary)
# ===================================================================
# All four MUST be set together; partial config is rejected at
# startup (GAP G4). See DEPLOY.md §2.3 for why R2 beats S3 on
# egress cost.

# Wave 13 Phase 3 — R2 account + bucket are fixed; only the keys rotate.
R2_ACCOUNT_ID=193b347aedeaafe35de0b5a534b2d9aa
R2_ACCESS_KEY_ID=CHANGEME
R2_SECRET_ACCESS_KEY=CHANGEME
R2_BUCKET=windycloud-userdata
# Auto-derived from R2_ACCOUNT_ID when blank.
R2_ENDPOINT=

# ===================================================================
# Database — RDS Postgres
# ===================================================================
# Format: postgresql+asyncpg://user:password@host:5432/dbname
# Host comes from `terraform output rds_endpoint`.

DATABASE_URL=postgresql+asyncpg://windy_cloud:CHANGEME@CHANGEME.rds.amazonaws.com:5432/windy_cloud

# ===================================================================
# Compute — RunPod Serverless (Phase 1)
# ===================================================================

RUNPOD_API_KEY=CHANGEME
RUNPOD_ENDPOINT_ID=CHANGEME
# Markup multiplier over RunPod's billed cost. 3.0 ≈ margin + free-tier subsidy.
STT_MARKUP=3.0
# Free minutes per user per billing cycle before charges kick in.
STT_FREE_MINUTES=10

# ===================================================================
# Compute — AWS SageMaker (Phase 2 fallback — leave blank at launch)
# ===================================================================

SAGEMAKER_ENDPOINT_NAME=

# ===================================================================
# AWS credentials
# ===================================================================
# Production uses the EC2 instance profile (windy-cloud-api) instead
# of keys — leave these blank in prod. Keys are only populated in
# staging/dev where no instance profile is available.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Wave 13 Phase 3 — us-east-1 per the TheWindstorm AWS account playbook.
# (The Wave 9 default was us-west-2 before we settled on the account.)
AWS_REGION=us-east-1

# ===================================================================
# Stripe (billing + plan changes — Wave 10 webhook business logic)
# ===================================================================

STRIPE_SECRET_KEY=CHANGEME
STRIPE_PUBLISHABLE_KEY=CHANGEME
# Rotate when suspected compromise; Stripe supports two active
# secrets simultaneously during cutover (DEPLOY.md §4).
STRIPE_WEBHOOK_SECRET=CHANGEME
# Price IDs surfaced on the upgrade page. Keep in lockstep with
# the Stripe dashboard product catalog.
STRIPE_PRICE_ID_PRO=price_CHANGEME
STRIPE_PRICE_ID_ULTRA=price_CHANGEME
STRIPE_PRICE_ID_MAX=price_CHANGEME

# ===================================================================
# Server
# ===================================================================

HOST=0.0.0.0
PORT=8200
LOG_LEVEL=info
# MUST be false in prod: flips openapi/docs off + drops localhost CORS.
DEV_MODE=false
# Comma-separated list. Must NOT include localhost in prod.
CORS_ORIGINS=https://windyword.ai,https://windycloud.com,https://cloud.windyfly.ai

# ===================================================================
# Tier quotas (bytes)
# ===================================================================

TIER_QUOTA_FREE=5368709120
TIER_QUOTA_PRO=107374182400
TIER_QUOTA_ULTRA=1099511627776
TIER_QUOTA_MAX=5497558138880
DEFAULT_STORAGE_QUOTA=5368709120
MAX_UPLOAD_SIZE=268435456
MAX_SERVERS_PER_USER=5

# ===================================================================
# Observability
# ===================================================================

SENTRY_DSN=CHANGEME

# ===================================================================
# Misc
# ===================================================================

PRICING_URL=https://windyword.ai/pricing
# MUST be false in prod — swaps in mock providers used by tests.
USE_MOCK_PROVIDERS=false
